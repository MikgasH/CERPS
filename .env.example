# PostgreSQL Configuration - Main Databases
# Database names for currency and user services
POSTGRES_CURRENCY_DB=currency_db
POSTGRES_USERS_DB=users_db

# Main PostgreSQL credentials (change in production!)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# PostgreSQL Configuration - Analytics Read-Only User
# Dedicated read-only user for analytics service (change in production!)
POSTGRES_ANALYTICS_USER=analytics_readonly
POSTGRES_ANALYTICS_PASSWORD=change_analytics_password_in_production

# JWT Configuration (generate secure key minimum 256 bits)
# Example generation: openssl rand -base64 32
JWT_SECRET=your-secret-key-min-256-bits-your-secret-key-min-256-bits

# Encryption Master Key (generate secure 256-bit key)
# Example generation: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your_base64_encoded_256bit_key_here_generate_with_openssl

# Optional: External API Keys
# FIXER_API_KEY=your_fixer_api_key
# EXCHANGERATES_API_KEY=your_exchangerates_api_key
# CURRENCYAPI_KEY=your_currencyapi_key

# Optional: Service URLs (defaults are used from docker-compose.yml)
# USER_SERVICE_URL=http://user-service:8081
# MOCK_SERVICE_1_URL=http://mock-service-1:8083
# MOCK_SERVICE_2_URL=http://mock-service-2:8084
# API_GATEWAY_URL=http://localhost:8000
