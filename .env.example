# PostgreSQL Configuration (local development)
POSTGRES_CURRENCY_DB=currency_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# Spring datasource (auto-configured by Railway in production)
# For local development these are set by docker-compose
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/currency_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me_in_production

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Admin API Key
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change_admin_api_key_in_production

# Encryption Master Key for provider API keys (AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your_base64_encoded_256bit_key_here

# External Rate Provider API Keys
# Add via Admin API after startup: POST /api/v1/admin/provider-keys
# Or set directly here for local development
# FIXER_API_KEY=your_fixer_api_key
# EXCHANGERATES_API_KEY=your_exchangerates_api_key
# CURRENCYAPI_KEY=your_currencyapi_key

# Gemini AI (required for /api/v1/ai/bank-commission)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Analytics Service URL (for inter-service communication)
CURRENCY_SERVICE_URL=http://localhost:8080
