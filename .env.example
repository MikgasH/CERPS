# PostgreSQL Configuration
POSTGRES_CURRENCY_DB=currency_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# Admin API Key (change in production!)
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change_admin_api_key_in_production

# Encryption Master Key (generate secure 256-bit key)
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=your_base64_encoded_256bit_key_here_generate_with_openssl

# External API Keys (optional - uncomment if using real providers)
# FIXER_API_KEY=your_fixer_api_key
# EXCHANGERATES_API_KEY=your_exchangerates_api_key
# CURRENCYAPI_KEY=your_currencyapi_key

# Gemini AI API key (required for /api/v1/ai/bank-commission)
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
