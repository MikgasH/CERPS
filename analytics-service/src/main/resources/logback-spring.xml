<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="SERVICE_NAME" value="analytics-service"/>

    <include resource="logback-common.xml"/>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
